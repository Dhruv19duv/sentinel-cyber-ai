{
  "name": "sentinel-ide-bridge",
  "displayName": "Sentinel IDE Bridge",
  "description": "VS Code extension for Sentinel Cyber AI — slash commands, diagnostics, and inline suggestions",
  "version": "0.1.0",
  "publisher": "sentinel-ai",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Security",
    "Other"
  ],
  "keywords": [
    "sentinel",
    "security",
    "ai",
    "bridge",
    "cybersecurity"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sentinel.analyze",
        "title": "Sentinel: Analyze Selection"
      },
      {
        "command": "sentinel.review",
        "title": "Sentinel: Review File"
      },
      {
        "command": "sentinel.scan",
        "title": "Sentinel: Scan Workspace"
      },
      {
        "command": "sentinel.connect",
        "title": "Sentinel: Connect to Bridge"
      },
      {
        "command": "sentinel.disconnect",
        "title": "Sentinel: Disconnect"
      },
      {
        "command": "sentinel.status",
        "title": "Sentinel: Show Status"
      }
    ],
    "keybindings": [
      {
        "command": "sentinel.analyze",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "sentinel.review",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "Sentinel IDE Bridge",
      "properties": {
        "sentinel.bridgeHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host for the Sentinel IDE Bridge server"
        },
        "sentinel.bridgePort": {
          "type": "number",
          "default": 9876,
          "description": "Port for the Sentinel IDE Bridge server"
        },
        "sentinel.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-connect to Sentinel bridge on startup"
        },
        "sentinel.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline diagnostics from Sentinel analysis"
        }
      }
    }
  }
}
